{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user (Teacher or Student)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["teacher", "student"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Class": {
      "title": "Class",
      "description": "A classroom created by a teacher",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "teacherId": { "type": "string" },
        "inviteCode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "teacherId", "inviteCode"]
    },
    "Assignment": {
      "title": "Assignment",
      "description": "Task assigned to students",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "classId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "teacherId": { "type": "string" }
      },
      "required": ["classId", "title", "teacherId"]
    },
    "Submission": {
      "title": "Submission",
      "description": "Student's work for an assignment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "assignmentId": { "type": "string" },
        "studentId": { "type": "string" },
        "content": { "type": "string" },
        "grade": { "type": "number" },
        "feedback": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["assignmentId", "studentId", "content"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/classes/{classId}": {
      "schema": "Class",
      "description": "Classroom data"
    },
    "/assignments/{assignmentId}": {
      "schema": "Assignment",
      "description": "Assignments created by teachers"
    },
    "/submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Student submissions"
    }
  }
}
